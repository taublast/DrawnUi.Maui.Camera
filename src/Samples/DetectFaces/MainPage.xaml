<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TestFaces.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:draw="http://schemas.appomobi.com/drawnUi/2023/draw"
    xmlns:ui="clr-namespace:CameraTests.UI">

    <Grid
        VerticalOptions="Fill" HorizontalOptions="Fill"
        Padding="16"
        BackgroundColor="Grey"
        RowDefinitions="Auto,Auto,*"
        RowSpacing="12">

        <!--  Top bar: button + spinner + status  -->
        <HorizontalStackLayout
            Grid.Row="0"
            Spacing="12"
            VerticalOptions="Center">
            <Button
                x:Name="PickPhotoBtn"
                Clicked="OnPickPhotoClicked"
                Text="Pick a Photo" />

            <Picker
                x:Name="ModePicker"
                SelectedIndex="0"
                SelectedIndexChanged="OnModeChanged"
                VerticalOptions="Center">
                <Picker.Items>
                    <x:String>Landmark</x:String>
                    <x:String>Rectangle</x:String>
                    <x:String>Mask (Spider-Man)</x:String>
                    <x:String>Hat (Cake)</x:String>
                </Picker.Items>
            </Picker>

        </HorizontalStackLayout>

        <!-- Manual confidence tuning for the detector. Values are normalized 0..1 thresholds. -->
        <Grid
            Grid.Row="1"
            ColumnDefinitions="Auto,72,Auto,72,Auto,72,Auto"
            ColumnSpacing="8"
            RowDefinitions="Auto"
            VerticalOptions="Center">

            <Label Grid.Column="0" Text="Det" VerticalTextAlignment="Center" />
            <Entry
                x:Name="DetectionConfidenceEntry"
                Grid.Column="1"
                HorizontalTextAlignment="Center"
                Keyboard="Numeric"
                Placeholder="0..1"
                Text="0.50" />

            <Label Grid.Column="2" Text="Pres" VerticalTextAlignment="Center" />
            <Entry
                x:Name="PresenceConfidenceEntry"
                Grid.Column="3"
                HorizontalTextAlignment="Center"
                Keyboard="Numeric"
                Placeholder="0..1"
                Text="0.50" />

            <Label Grid.Column="4" Text="Track" VerticalTextAlignment="Center" />
            <Entry
                x:Name="TrackingConfidenceEntry"
                Grid.Column="5"
                HorizontalTextAlignment="Center"
                Keyboard="Numeric"
                Placeholder="0..1"
                Text="0.50" />

            <Button
                x:Name="ApplyConfidenceButton"
                Grid.Column="6"
                Clicked="OnApplyConfidenceClicked"
                Text="Apply" />
        </Grid>

        <!--  Camera preview or selected image  -->
        <Grid Grid.Row="2" VerticalOptions="Fill" HorizontalOptions="Fill">

            <ui:AppCanvas
                x:Name="MainCanvas"
                BackgroundColor="Black"
                Gestures="Lock"
                HorizontalOptions="Fill"
                RenderingMode="Accelerated"
                VerticalOptions="Fill">

                <draw:SkiaLayout HorizontalOptions="Fill" VerticalOptions="Fill">

                    <ui:AppCamera
                        x:Name="CameraControl"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill" />

                    <draw:SkiaLabelFps
                        UseCache="GPU"
                        Margin="0,0,4,24"
                        BackgroundColor="DarkRed"
                        ForceRefresh="False"
                        HorizontalOptions="End"
                        Rotation="-45"
                        TextColor="White"
                        VerticalOptions="End"
                        ZIndex="100" />

                </draw:SkiaLayout>

            </ui:AppCanvas>

            <Label
                TextColor="LightGreen"
                FontSize="10"
                x:Name="StatusLabel"
                Text="" />

            <Image
                x:Name="SelectedImage"
                Aspect="AspectFit"
                BackgroundColor="Black"
                IsVisible="False" />

        </Grid>

    </Grid>

</ContentPage>

